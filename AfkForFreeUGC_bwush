if getgenv().AfkForFreeUGC_bwush1 then return end
getgenv().AfkForFreeUGC_bwush1 = true

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "DebugCountdown"
screenGui.ResetOnSpawn = false
screenGui.Parent = game:GetService("CoreGui")

local debugLabel = Instance.new("TextLabel")
debugLabel.Size = UDim2.new(0, 400, 0, 50)
debugLabel.Position = UDim2.new(0.5, -200, 0.5, -25)
debugLabel.BackgroundColor3 = Color3.new(0, 0, 0)
debugLabel.BackgroundTransparency = 0.5
debugLabel.TextColor3 = Color3.new(1, 1, 0)
debugLabel.TextScaled = true
debugLabel.Font = Enum.Font.Code
debugLabel.Parent = screenGui

local QueueOnTeleport = (syn and syn.queue_on_teleport) or queue_on_teleport or (fluxus and fluxus.queue_on_teleport)
local SCRIPT_URL = "https://raw.githubusercontent.com/Hi2983488r93993/RobloxUGC_Scripts/refs/heads/main/AfkForFreeUGC_bwush"
local allowRejoin = true 

pcall(function()
    if QueueOnTeleport then
        QueueOnTeleport("loadstring(game:HttpGet('"..SCRIPT_URL.."'))()")
    end
end)

if not game:IsLoaded() then
    game.Loaded:Wait()
end

local player = game.Players.LocalPlayer
local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local GuiService = game:GetService("GuiService")
local TweenService = game:GetService("TweenService")

local function CheckServerSecurity()
    if #Players:GetPlayers() >= 2 then
        allowRejoin = false 
        player:Kick("\nServer có " .. #Players:GetPlayers() .. " người! Vô server riêng dùm coi 😡")
    end
end

CheckServerSecurity()
Players.PlayerAdded:Connect(CheckServerSecurity)

task.spawn(function()
    if not allowRejoin then return end
    
    while true do
        local character = player.Character or player.CharacterAdded:Wait()
        local hrp = character:WaitForChild("HumanoidRootPart")
        
        -- QUÉT LIÊN TỤC: Tìm Stage 10
        local stage10 = workspace:FindFirstChild("obby") and workspace.obby:FindFirstChild("Stages") and workspace.obby.Stages:FindFirstChild("Stage 10")

        if stage10 then
            -- NẾU THẤY STAGE 10: Ưu tiên Tween tới ngay
            local distance = (hrp.Position - stage10.Position).Magnitude
            local tween = TweenService:Create(hrp, TweenInfo.new(distance / 200, Enum.EasingStyle.Linear), {CFrame = stage10.CFrame})
            tween:Play()
            tween.Completed:Wait()
        else
            -- NẾU KHÔNG THẤY: Chạy logic tọa độ và ProximityPrompt (không dùng vòng lặp vô hạn ở đây để có thể quay lại check Stage 10)
            local targetCFrame = CFrame.new(41338, -71, -21)
            local distance = (hrp.Position - targetCFrame.Position).Magnitude
            local tween = TweenService:Create(hrp, TweenInfo.new(distance / 200, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
            tween:Play()
            tween.Completed:Wait()

            -- Quét nhanh ProximityPrompt 1 lần mỗi chu kỳ nếu đang ở tọa độ này
            local closestPrompt = nil
            local minDistance = 30
            for _, item in pairs(workspace:GetDescendants()) do
                if item:IsA("ProximityPrompt") then
                    local promptPos = item.Parent:IsA("BasePart") and item.Parent.Position or item.Parent:GetPivot().Position
                    local dist = (hrp.Position - promptPos).Magnitude
                    if dist < minDistance then
                        minDistance = dist
                        closestPrompt = item
                    end
                end
            end
            if closestPrompt then
                fireproximityprompt(closestPrompt)
            end
        end
        task.wait(0.1) -- Delay nhỏ để vòng lặp quét liên tục mà không gây lag
    end
end)

local function RejoinLogic()
    if not allowRejoin then return end
    if game.PrivateServerId ~= "" then
        TeleportService:TeleportToPrivateServer(game.PlaceId, game.PrivateServerId, {player})
    else
        TeleportService:Teleport(game.PlaceId, player)
    end
end

GuiService.ErrorMessageChanged:Connect(function()
    if allowRejoin then
        task.wait(0.1)
        RejoinLogic()
    end
end)

local timeLeft = 8.1
while timeLeft > 0 do
    debugLabel.Text = string.format("Chuẩn bị Kick trong: %.1fS", timeLeft)
    task.wait(0.1)
    timeLeft = timeLeft - 0.1
end

if allowRejoin then
    player:Kick("Đang Rejoin để farm Points tiếp...")
end
