-- Tự động chạy tính năng Get 100lucks Badges (TP + Fire)
local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- Hàm thực hiện logic lấy badge (giữ nguyên 100% tính năng gốc)
local function startMysteryFarm()
    while true do -- Chạy liên tục không ngừng
        for i = 1, 999 do
            task.spawn(function()
                local character = player.Character
                if not character then return end
                local rootPart = character:FindFirstChild("HumanoidRootPart")
                if not rootPart then return end

                -- Tìm các nút MysteryButton_Round trong Workspace
                local buttons = {}
                for _, m in ipairs(workspace:GetChildren()) do
                    if m.Name == "MysteryButton_Round" then
                        local p = m:FindFirstChildWhichIsA("ProximityPrompt", true)
                        if p then table.insert(buttons, p) end
                    end
                end

                -- Thực hiện Teleport và Fire Prompt
                for _, prompt in ipairs(buttons) do
                    if not character or not character:FindFirstChild("Humanoid") or character.Humanoid.Health <= 0 then break end
                    if prompt and prompt.Parent and prompt.Enabled then
                        rootPart.CFrame = prompt.Parent.CFrame
                        task.wait(0.01) 
                        fireproximityprompt(prompt)
                        
                        local checkStartTime = tick()
                        repeat
                            task.wait() 
                            if tick() - checkStartTime > 10 then break end 
                        until not prompt or not prompt.Parent or not prompt.Enabled or not prompt:IsDescendantOf(game)
                        task.wait(0.05) 
                    end
                end
            end)
        end
        task.wait(0.05) -- Nghỉ một chút trước khi lặp lại vòng quét mới
    end
end

-- Kích hoạt chạy ngay lập tức
task.spawn(startMysteryFarm)
