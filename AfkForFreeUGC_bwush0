-- // 2. TÍNH NĂNG MỚI: BRING STAGE 10 (Hỗ trợ khi Reset)
task.spawn(function()
    while true do
        if allowRejoin then
            pcall(function()
                local char = player.Character or player.CharacterAdded:Wait()
                local hrp = char:WaitForChild("HumanoidRootPart")
                local stage10 = workspace:FindFirstChild("obby") and workspace.obby:FindFirstChild("Stages") and workspace.obby.Stages:FindFirstChild("Stage 10")
                
