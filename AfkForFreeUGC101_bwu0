-- Logic di chuyển chính
task.spawn(function()
    if not allowRejoin then return end
    
    while true do
        local character = player.Character or player.CharacterAdded:Wait()
        local hrp = character:WaitForChild("HumanoidRootPart")
        
        -- Hàm kiểm tra Stage 10 an toàn
        local function GetStage10()
            local obby = workspace:FindFirstChild("obby")
            if obby then
                local stages = obby:FindFirstChild("Stages")
                if stages then
                    return stages:FindFirstChild("Stage 10")
                end
            end
            return nil
        end

        local stage10 = GetStage10()

        if stage10 then
            -- LOGIC STAGE 10: Tốc độ 700 (Dựa trên distance / 700)
            local distance = (hrp.Position - stage10.Position).Magnitude
            local tween = TweenService:Create(hrp, TweenInfo.new(distance / 700, Enum.EasingStyle.Linear), {CFrame = stage10.CFrame})
            tween:Play()
            tween.Completed:Wait()
        else
            -- LOGIC TỌA ĐỘ PHỤ: Tốc độ 200
            local targetPos = CFrame.new(41338, -71, -21)
            
            -- KIỂM TRA XEM CÓ PROXIMITYPROMPT NÀO Ở GẦN TỌA ĐỘ MỤC TIÊU KHÔNG
            local function IsTargetAreaLoaded()
                for _, obj in pairs(workspace:GetDescendants()) do
                    if obj:IsA("ProximityPrompt") then
                        local parent = obj.Parent
                        if parent and parent:IsA("BasePart") then
                            if (parent.Position - targetPos.Position).Magnitude < 100 then
                                return true
                            end
                        end
                    end
                end
                return false
            end

            -- CHỈ BẮT ĐẦU TWEEN KHI THỰC SỰ CÓ MỤC TIÊU ĐỂ TRÁNH BAY VÔ ĐỊNH
            local currentStage10 = GetStage10()
            if not currentStage10 and not IsTargetAreaLoaded() then
                debugLabel.Text = "Waiting for Stage or Target Area..."
                repeat 
                    task.wait(1) 
                    currentStage10 = GetStage10()
                until currentStage10 or IsTargetAreaLoaded()
            end

            -- Nếu trong lúc đợi mà Stage 10 xuất hiện thì quay lại đầu vòng lặp để ưu tiên Stage 10
            if GetStage10() then
                -- Tiếp tục vòng lặp chính
            else
                local distance = (hrp.Position - targetPos.Position).Magnitude
                local tween = TweenService:Create(hrp, TweenInfo.new(distance / 200, Enum.EasingStyle.Linear), {CFrame = targetPos})
                tween:Play()
                
                -- Trong khi đang bay tới tọa độ phụ, vẫn phải check xem Stage 10 có xuất hiện đột ngột không
                local reached = false
                local connection
                connection = tween.Completed:Connect(function()
                    reached = true
                    connection:Disconnect()
                end)

                -- Vòng lặp kiểm tra Stage 10 khi đang di chuyển
                while not reached do
                    if GetStage10() then
                        tween:Cancel()
                        connection:Disconnect()
                        break
                    end
                    task.wait(0.1)
                end

                -- Nếu đã tới đích (tọa độ phụ) và vẫn không có Stage 10 thì mới bấm nút
                if reached and not GetStage10() then
                    local g = nil
                    local h = 30
                    for i, j in pairs(workspace:GetDescendants()) do
                        if j:IsA("ProximityPrompt") then
                            local promptParent = j.Parent
                            if promptParent then
                                local pos = promptParent:IsA("BasePart") and promptParent.Position or promptParent:GetPivot().Position
                                local k = (hrp.Position - pos).Magnitude
                                if k < h then
                                    h = k
                                    g = j
                                end
                            end
                        end
                    end
                    if g then fireproximityprompt(g) end
                end
            end
        end
        task.wait(0.1)
    end
end)

local function RejoinLogic()
    if not allowRejoin then return end
    if game.PrivateServerId ~= "" then
        TeleportService:TeleportToPrivateServer(game.PlaceId, game.PrivateServerId, {player})
    else
        TeleportService:Teleport(game.PlaceId, player)
    end
end

GuiService.ErrorMessageChanged:Connect(function()
    if allowRejoin then
        task.wait(0.1)
        RejoinLogic()
    end
end)


