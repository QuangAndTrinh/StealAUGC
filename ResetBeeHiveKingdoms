-- Đợi game load xong mới chạy
if not game:IsLoaded() then
    game.Loaded:Wait()
end

local RS = game:GetService("ReplicatedStorage")
local PL = game:GetService("Players")
local lp = PL.LocalPlayer
local char = lp.Character or lp.CharacterAdded:Wait()
local hrp = char:WaitForChild("HumanoidRootPart")

--// Cấu hình Loop Item (Chạy riêng biệt)
local args = {
    {
        "UGC Seedling",
        {}
    }
}

task.spawn(function()
    local useRemote = RS:WaitForChild("Remotes"):WaitForChild("UseItem")
    while true do 
        useRemote:FireServer(unpack(args))
        task.wait(0.3) -- Chỉnh thời gian delay tại đây (0.3s là khá nhanh)
    end
end)

--// 1. Nhập mã Codes (Chạy 1 lần)
local remoteCode = RS:WaitForChild("Remotes"):WaitForChild("EnterCode")
local codes = {"1KLikes", "3GYAY", "TestCode3", "Launch", "BIG", "JoinGroup", "StoryTime", "Dragon", "Enchanted", "Rainbows", "Sunshine"}

for _, c in ipairs(codes) do
    remoteCode:FireServer(c)
    task.wait(0.1)
end

--// 2. Di chuyển và Reset Data
hrp.CFrame = CFrame.new(-51, 4, 144)
task.wait(1)

-- Thực hiện chạm vào ResetData
local resetPart = workspace:FindFirstChild("ResetData")
if resetPart then
    firetouchinterest(hrp, resetPart, 0)
    task.wait(0.1)
    firetouchinterest(hrp, resetPart, 1)
end
